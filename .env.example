# =============================================================================
# Greene Platform — Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in real values for your environment.
# .env is listed in .gitignore and must NEVER be committed to the repository.
#
#   cp .env.example .env
#
# For CI/CD (staging & prod) inject these as GitHub Actions secrets /
# Docker Compose environment variables — never store them in any committed file.
# =============================================================================

# -----------------------------------------------------------------------------
# Active Spring profile  (dev | staging | prod)
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
SERVER_PORT=8080

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
DB_URL=jdbc:postgresql://localhost:5432/greene_db
DB_USERNAME=greene_user
DB_PASSWORD=change_me_before_use

# Used by the postgres Docker Compose service (mirrors the values above)
POSTGRES_DB=greene_db
POSTGRES_USER=greene_user
POSTGRES_PASSWORD=change_me_before_use

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
# RS256 key pair.  Generate with:
#   openssl genrsa -out jwt_private.pem 2048
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# Provide the raw PEM content (newlines replaced with \n) or a file path.
JWT_PRIVATE_KEY=CHANGE_ME
JWT_PUBLIC_KEY=CHANGE_ME
# Access token lifetime in minutes
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
# Refresh token lifetime in days
JWT_REFRESH_TOKEN_EXPIRY_DAYS=30

# -----------------------------------------------------------------------------
# Amazon SES (email — OTP, welcome, notifications)
# -----------------------------------------------------------------------------
AWS_SES_REGION=ap-south-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_SES_FROM_ADDRESS=no-reply@example.com

# -----------------------------------------------------------------------------
# Firebase Cloud Messaging (push notifications)
# -----------------------------------------------------------------------------
# Path to the Firebase service-account JSON file, or inline JSON content.
FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-service-account.json

# -----------------------------------------------------------------------------
# Object Storage — Backblaze B2 / S3-compatible (media files, DB backups)
# -----------------------------------------------------------------------------
S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
S3_BUCKET=greene-media
S3_REGION=us-west-004
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME

